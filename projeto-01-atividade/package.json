{
    "name": "ecommerce-recomendations-with-ml",
    "version": "1.0.0",
    "description": "An e-commerce recommendation system with TensorFlow.js",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "build:css": "npx @tailwindcss/cli -i ./src/input.css -o ./style.css",
        "watch:css": "npx @tailwindcss/cli -i ./src/input.css -o ./style.css --watch",
        "serve": "browser-sync -w . --server --files 'index.html, style.css, src/**/*.js, src/**/*.html' --port 3000",
        "start": "concurrently \"npm run watch:css\" \"npm run serve\"",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "keywords": [
        "ecommerce",
        "tensorflow",
        "recommendation",
        "javascript"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "mysql2": "^3.11.0",
        "neo4j-driver": "^5.26.0"
    },
    "devDependencies": {
        "@tailwindcss/cli": "^4.2.1",
        "browser-sync": "^3.0.4",
        "concurrently": "^9.2.1",
        "tailwindcss": "^4.2.1"
    }
}
